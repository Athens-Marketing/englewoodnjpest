---
import { site } from "../data/site.js";
const { faqs = [], heading = "Frequently Asked Questions" } = Astro.props;
---
{faqs.length > 0 && (
  <section class="faq">
    <div class="wrap faq-in">
      <span class="eyebrow">Answers</span>
      <h2 class="sec-h">{heading}</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary><span>{f.q}</span><span class="faq-sign" aria-hidden="true"></span></summary>
            <div class="faq-a"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
      <p class="faq-call">Still have a question? Call <a href={site.phoneHref}>{site.phone}</a> and talk it through with a local pro.</p>
    </div>
  </section>
)}
