---
import Base from "../components/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CtaBand from "../components/CtaBand.astro";
import FaqList from "../components/FaqList.astro";
import PestIcon from "../components/PestIcon.astro";
import { site, primaryServices, heroPills, pestStrip, footerAreas } from "../data/site.js";
import { services } from "../data/services.js";
import { posts } from "../data/blog.js";
import { imgUrl } from "../data/imgmap.js";
import { orgNode, websiteNode, itemListNode, faqNode } from "../lib/schema.js";

const title = `Englewood Pest Control, NJ | Local Exterminator | ${site.phone}`;
const description = "Local pest control in Englewood, NJ. Source-first treatment for ants, rodents, termites, roaches, stinging insects, mosquitoes, ticks, and bed bugs across Bergen County. Call (201) 409-2540.";

const why = [
  { icon: "pin", t: "Local to Bergen County", p: "The work starts with the pressure this area actually has: winter rodents, spring ants and termites, summer ticks, and the fall stink bug push." },
  { icon: "target", t: "Source over symptom", p: "Colonies, nests, harborage, and entry points get treated, not just the ants on the counter or the wasp on the patio." },
  { icon: "house", t: "Perimeter to roofline", p: "The exterior comes first: the foundation, the sill, the utility lines, and the roofline, where the pests actually get in." },
  { icon: "shield", t: "Built for multifamily", p: "Roaches, bed bugs, and rodents travel between units, so shared walls, utility chases, and neighboring units get considered." },
  { icon: "clock", t: "Tuned to the seasons", p: "A recurring option keeps a fresh barrier in place through New Jersey's long, changing pest calendar." },
  { icon: "phone", t: "A straight phone call", p: "No forms and no runaround. Describe the pest and the room, and get matched with a provider who covers your street." },
];
const process = [
  { icon: "phone", t: "Call", p: "Tell us the pest, the room, and how long it has been going on." },
  { icon: "search", t: "Match", p: "We connect you with a local exterminator who covers your Englewood address." },
  { icon: "bolt", t: "Treat", p: "The provider treats the source and the entry points, not just the surface." },
  { icon: "check", t: "Follow up", p: "Recurring options keep the protection working through the seasons." },
];
const badges = [
  { icon: "bolt", b: "Fast scheduling", s: "Get on the calendar at the earliest open window." },
  { icon: "pin", b: "Bergen County local", s: "Providers who know Englewood and the surrounding towns." },
  { icon: "target", b: "Source-first treatment", s: "The nest, the colony, and the way in." },
  { icon: "rodent", b: "Exclusion included", s: "Sealing the gaps, not just trapping and spraying." },
];
const homeFaqs = [
  { q: "What areas do you cover?", a: "Englewood and the surrounding Bergen County communities, including Teaneck, Fort Lee, Tenafly, Bergenfield, Leonia, and Hackensack. Call (201) 409-2540 and we will match you with a local provider covering your address." },
  { q: "What pests do you handle?", a: "The full New Jersey mix: ants, rodents, cockroaches, subterranean termites, stinging insects, mosquitoes and ticks, bed bugs, and fall invaders like stink bugs and boxelder bugs. Each is treated at the source with the method that fits it." },
  { q: "How fast can someone come out?", a: "Call and describe the problem, and we will match you with a local exterminator and get you on the schedule at the earliest open window. Urgent stinging-insect and rodent issues are prioritized." },
  { q: "Do you treat apartments and businesses?", a: "Yes. In multifamily buildings and food businesses, roaches, bed bugs, and rodents need thorough harborage treatment and attention to shared walls and neighboring units. Providers experienced in that work cover Englewood and the surrounding towns." },
];
const jsonld = [orgNode(), websiteNode(), itemListNode(primaryServices), faqNode(homeFaqs)];
const topServices = services.slice(0, 6);
const homePosts = posts.slice(0, 4);
---
<Base title={title} description={description} path="/" jsonld={jsonld}>
  <Header />
  <main id="main">

    <section class="hero">
      <div class="hero-img"><img src={imgUrl("hero.jpg")} alt="Liberty Square in Englewood, New Jersey" fetchpriority="high" /></div>
      <div class="hero-scrim"></div>
      <div class="hero-stars"></div>
      <div class="wrap hero-in">
        <div class="hero-panel">
          <span class="hero-flag"><PestIcon name="star" cls="ic" /> Englewood &amp; Bergen County, NJ</span>
          <h1>Englewood's Local <span class="accent">Pest Control</span>, Done Right.</h1>
          <p>From winter rodents to summer ticks to the fall stink bug invasion, we connect you with an experienced local exterminator who treats the pest at the source and seals the way in.</p>
          <div class="hero-pills">
            {heroPills.map((p) => (<a class="hero-pill" href={`/${p.slug}/`}><PestIcon name={p.icon} cls="ic" /> {p.label}</a>))}
          </div>
          <a class="btn btn--red btn--lg hero-cta" href={site.phoneHref}><PestIcon name="phone" cls="ic" /> Call {site.phone}</a>
        </div>
        <aside class="hero-card">
          <span class="badge"><PestIcon name="pin" cls="ic" /> Serving all of Englewood</span>
          <h3>Talk to a local pro</h3>
          <p>Describe the pest and get matched with a provider who covers your street.</p>
          <a class="num" href={site.phoneHref}>{site.phone}</a>
          <a class="btn btn--navy btn--full" href={site.phoneHref}><PestIcon name="phone" cls="ic" /> Call now</a>
          <ul>
            <li><PestIcon name="check" cls="ic" /> Source-first treatment, not just surface spraying</li>
            <li><PestIcon name="check" cls="ic" /> Entry points sealed, not just trapped</li>
            <li><PestIcon name="check" cls="ic" /> Coverage across Bergen County</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="badges">
      <div class="wrap">
        <div class="badge-row">
          {badges.map((b) => (
            <div class="badge-card">
              <span class="badge-ic"><PestIcon name={b.icon} cls="ic" /></span>
              <b>{b.b}</b><span>{b.s}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="intro">
      <div class="wrap intro-in">
        <div class="intro-tx">
          <span class="eyebrow">Local pest control for Englewood</span>
          <h2>Effective pest control for homes and businesses across <span class="accent">Bergen County</span></h2>
          <p class="lead">Englewood sits minutes from New York City, with older colonials and Victorians, prewar and newer multifamily, and a busy downtown corridor, and every one of those shapes which pests show up and when.</p>
          <p>Most local pest problems are not random. Ants trail indoors when the warm months arrive. Mice and rats push in with the first cold snap. German roaches move through multifamily buildings, subterranean termites work up from the soil into older wood, and every fall the stink bugs gather on warm walls. Treat only what you see inside, and it all comes back.</p>
          <p>Our approach flips that. We match you with a provider who works the exterior first, the perimeter, the foundation and sill, the utility lines, and the roofline, treats the source of each pest, and keeps the protection working on a schedule tuned to the New Jersey seasons. It is pest control shaped by how Englewood homes are actually built and how these pests actually behave.</p>
          <a class="btn btn--red" href="/services/"><PestIcon name="shield" cls="ic" /> See all services</a>
        </div>
        <aside class="intro-card">
          <span class="num">{site.phone}</span>
          <h3>Get matched with a local pro</h3>
          <p>One phone call connects you with an experienced local exterminator covering your Englewood address. No forms.</p>
          <ul>
            <li><PestIcon name="check" cls="ic" /> Describe the pest and the room</li>
            <li><PestIcon name="check" cls="ic" /> Get on the schedule at the earliest window</li>
            <li><PestIcon name="check" cls="ic" /> Coverage across Bergen County and the surrounding towns</li>
          </ul>
          <a class="btn btn--red btn--full" href={site.phoneHref}><PestIcon name="phone" cls="ic" /> Call {site.phone}</a>
        </aside>
      </div>
    </section>

    <section class="why">
      <div class="wrap">
        <span class="eyebrow" style="display:block;text-align:center">Why homeowners call us</span>
        <h2 class="sec-h">Why hire a <span class="accent">local pro</span> for your pest control</h2>
        <div class="why-grid">
          {why.map((w, i) => (
            <div class="whycard">
              <span class="whycard-num">{i + 1}</span>
              <span class="whycard-ic"><PestIcon name={w.icon} cls="ic" /></span>
              <h3>{w.t}</h3>
              <p>{w.p}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="statement">
      <div class="wrap statement-in">
        <div>
          <h2>Pest problems do not wait. Neither should you.</h2>
          <p>A wasp nest by the door, mice in the walls, or ants on the counter only gets harder the longer it sits. Call and get matched with a local exterminator who can treat it at the source.</p>
        </div>
        <div class="statement-side">
          <a class="btn btn--ink btn--lg" href={site.phoneHref}><PestIcon name="phone" cls="ic" /> {site.phone}</a>
          <span class="statement-note">Serving Englewood &amp; Bergen County</span>
        </div>
      </div>
    </section>

    <section class="region">
      <div class="wrap">
        <span class="eyebrow" style="display:block;text-align:center">Service area</span>
        <h2 class="sec-h">Serving Englewood &amp; <span class="accent">Bergen County</span></h2>
        <div class="region-panel">
          <div class="region-map">
            <div class="hero-stars"></div>
            <b>Englewood, NJ 07631</b>
            <p>Local pest control for Englewood and the surrounding Bergen County communities, from the Palisade Avenue corridor to the wooded edges of the county.</p>
            <a class="btn btn--red" href={site.phoneHref}><PestIcon name="phone" cls="ic" /> {site.phone}</a>
          </div>
          <div class="region-body">
            <p class="region-eyebrow">Towns we cover</p>
            <div class="region-grid">
              <a href="/"><PestIcon name="pin" cls="ic" /> Englewood</a>
              {footerAreas.map((a) => (<a href={`/${a.slug}/`}><PestIcon name="pin" cls="ic" /> {a.name}</a>))}
              <a href="/pest-control-in-teaneck/"><PestIcon name="pin" cls="ic" /> Englewood Cliffs</a>
              <a href="/pest-control-in-leonia/"><PestIcon name="pin" cls="ic" /> Palisades Park</a>
            </div>
            <p class="region-note">Not sure if we cover your street? Call <a href={site.phoneHref}>{site.phone}</a> and we will let you know.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="pests">
      <div class="wrap">
        <span class="eyebrow" style="display:block;text-align:center">What we handle</span>
        <h2 class="sec-h">Common pests we <span class="accent">protect against</span></h2>
        <div class="pest-row">
          {pestStrip.map((p) => (
            <div class="pest-chip">
              <span class="pest-chip-ic"><PestIcon name={p.icon} cls="ic" /></span>
              <b>{p.label}</b>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="process">
      <div class="wrap">
        <span class="eyebrow" style="display:block;text-align:center">How it works</span>
        <h2 class="sec-h">From first call to a <span class="accent">pest-free home</span></h2>
        <div class="process-grid">
          {process.map((s, i) => (
            <div class="pcard">
              <span class="pcard-step">{i + 1}</span>
              <span class="pcard-ic"><PestIcon name={s.icon} cls="ic" /></span>
              <h3>{s.t}</h3>
              <p>{s.p}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="split">
      <div class="wrap">
        <span class="eyebrow" style="display:block;text-align:center">Homes &amp; businesses</span>
        <h2 class="sec-h">Pest control for <span class="accent">every property</span></h2>
        <div class="split-grid">
          <article class="scard">
            <div class="scard-img"><img src={imgUrl("residential.jpg")} alt="An older residential home in Bergen County, New Jersey" loading="lazy" /></div>
            <div class="scard-b">
              <h3>Residential</h3>
              <p>From historic colonials to newer homes and condos, we match you with a provider who treats the perimeter, the foundation, and the entry points, and keeps the protection working through the seasons.</p>
              <a class="scard-go" href="/general-pest-control-in-englewood/">Explore home pest control <PestIcon name="check" cls="ic" /></a>
            </div>
          </article>
          <article class="scard">
            <div class="scard-img"><img src={imgUrl("commercial.jpg")} alt="A local storefront on a New Jersey commercial street" loading="lazy" /></div>
            <div class="scard-b">
              <h3>Commercial</h3>
              <p>Apartments, restaurants, and storefronts along the Palisade Avenue corridor face steady roach, rodent, and bed bug pressure. A consistent, documented program keeps it under control.</p>
              <a class="scard-go" href="/contact/">Talk about commercial service <PestIcon name="check" cls="ic" /></a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="blogrow">
      <div class="wrap">
        <span class="eyebrow" style="display:block;text-align:center">From the blog</span>
        <h2 class="sec-h">The local <span class="accent">pest journal</span></h2>
        <div class="blogrow-grid">
          {homePosts.map((p) => (
            <a class="bcard" href={`/blog/${p.slug}/`}>
              <span class="bcard-img"><img src={imgUrl(p.img)} alt={p.imgAlt} loading="lazy" /></span>
              <span class="bcard-b">
                <span class="bcard-tag">{p.tag}</span>
                <h3>{p.title}</h3>
                <span class="bcard-go">Read article <PestIcon name="check" cls="ic" /></span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="values">
      <div class="wrap">
        <div class="hero-stars"></div>
        <span class="eyebrow" style="display:block;text-align:center">What we stand for</span>
        <h2 class="sec-h">Local service you can count on</h2>
        <div class="val-grid">
          <div class="valcard"><span class="valcard-ic"><PestIcon name="pin" cls="ic" /></span><h3>Local accountability</h3><p>Providers who work Englewood and Bergen County and stand behind the job, not a distant call center.</p></div>
          <div class="valcard"><span class="valcard-ic"><PestIcon name="check" cls="ic" /></span><h3>Straight answers</h3><p>Clear talk about the pest, the plan, and the follow-up, without overpromising a permanent fix in one visit.</p></div>
          <div class="valcard"><span class="valcard-ic"><PestIcon name="shield" cls="ic" /></span><h3>Neighborhood coverage</h3><p>From high-rises in Fort Lee to wooded lots in Tenafly, matched to how your property is actually built.</p></div>
        </div>
      </div>
    </section>

    <FaqList faqs={homeFaqs} heading="Englewood pest control questions" />
    <CtaBand />
  </main>
  <Footer />
</Base>
