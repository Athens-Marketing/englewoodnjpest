---
import Base from "../components/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { site } from "../data/site.js";
import { orgNode, breadcrumb } from "../lib/schema.js";
const path = "/privacy-policy/";
const title = `Privacy Policy | ${site.brand}`;
const description = "Privacy policy for Englewood Pest Control describing what information we collect and how calls placed through this site are handled.";
const crumbs = [{ name: "Home", path: "/" }, { name: "Privacy Policy", path }];
const jsonld = [orgNode(), breadcrumb(crumbs)];
---
<Base title={title} description={description} path={path} jsonld={jsonld}>
  <Header />
  <main id="main">
    <section class="phero">
      <div class="phero-stars"></div>
      <div class="phero-scrim"></div>
      <div class="wrap phero-in phero-in--area">
        <span class="phero-kick">Legal</span>
        <h1>Privacy Policy</h1>
        <p>How we handle information from visitors and callers to {site.domain}.</p>
      </div>
    </section>
    <Breadcrumbs items={crumbs} />
    <section class="sbody">
      <div class="wrap sbody-in sbody-in--solo">
        <article class="sbody-main">
          <p class="lead">This policy explains what information {site.brand} collects through {site.domain} and how it is used. By using this site or calling the number listed, you agree to the practices described here.</p>
          <h2>Information we collect</h2>
          <p>When you call the number on this site, we may collect your name, phone number, address or service area, and details about the pest issue you describe. We collect this information so a pest control provider can respond to your request.</p>
          <h2>How calls are handled</h2>
          <p>{site.brand} operates as a lead-generation and referral service. Calls placed through this site may be recorded for quality and routed to an independent, third-party pest control provider that services your area. We do not guarantee that any specific company will handle your request, and service availability varies by location within Englewood and the surrounding Bergen County communities.</p>
          <h2>How we use information</h2>
          <p>Information you provide is used to connect you with a provider, respond to your inquiry, improve this site, and comply with legal obligations. We do not sell your personal information to unrelated third parties for their own marketing.</p>
          <h2>Cookies and analytics</h2>
          <p>This site may use cookies and standard analytics tools to understand how visitors use the pages so we can improve them. You can control cookies through your browser settings.</p>
          <h2>Data retention and security</h2>
          <p>We retain request information only as long as needed to serve your inquiry and meet legal requirements, and we take reasonable measures to protect it. No method of transmission over the internet is completely secure.</p>
          <h2>Your choices</h2>
          <p>You may ask us not to contact you further at any time. To request that we update or delete your information, call {site.phone} or email {site.email}.</p>
          <h2>Changes to this policy</h2>
          <p>We may update this policy from time to time. Continued use of the site after changes are posted means you accept the revised policy.</p>
          <h2>Contact</h2>
          <p>Questions about this policy? Call {site.phone} or email {site.email}.</p>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</Base>
