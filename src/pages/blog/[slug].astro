---
import Base from "../../components/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FaqList from "../../components/FaqList.astro";
import CtaBand from "../../components/CtaBand.astro";
import PestIcon from "../../components/PestIcon.astro";
import { site } from "../../data/site.js";
import { posts, postBySlug } from "../../data/blog.js";
import { serviceBySlug } from "../../data/services.js";
import { imgUrl } from "../../data/imgmap.js";
import { orgNode, articleNode, faqNode, breadcrumb } from "../../lib/schema.js";
export function getStaticPaths() {
  return posts.map((p) => ({ params: { slug: p.slug }, props: { slug: p.slug } }));
}
const { slug } = Astro.props;
const p = postBySlug[slug];
const path = `/blog/${p.slug}/`;
const related = (p.related || []).map((r) => serviceBySlug[r]).filter(Boolean);
const crumbs = [{ name: "Home", path: "/" }, { name: "Blog", path: "/blog/" }, { name: p.title, path }];
const jsonld = [orgNode(), articleNode({ headline: p.title, description: p.excerpt, path, datePublished: p.datePublished }), faqNode(p.faqs), breadcrumb(crumbs)];
---
<Base title={`${p.title} | ${site.brand}`} description={p.excerpt} path={path} jsonld={jsonld} ogType="article">
  <Header />
  <main id="main">
    <section class="phero phero--post">
      <div class="phero-img"><img src={imgUrl(p.img)} alt="" /></div>
      <div class="phero-stars"></div>
      <div class="phero-scrim"></div>
      <div class="wrap phero-in phero-in--area">
        <span class="phero-kick">{p.tag} · {p.read}</span>
        <h1>{p.title}</h1>
        <p class="post-meta">Published {p.dateLabel}</p>
      </div>
    </section>
    <Breadcrumbs items={crumbs} />
    <section class="sbody">
      <div class="wrap sbody-in">
        <article class="sbody-main">
          <figure class="post-fig"><img src={imgUrl(p.img)} alt={p.imgAlt} fetchpriority="high" /></figure>
          <p class="lead">{p.excerpt}</p>
          {p.body.map((sec) => (
            <>
              <h2>{sec.h2}</h2>
              {sec.p.map((para) => (<p>{para}</p>))}
            </>
          ))}
          <div class="inline-cta">
            <span class="inline-ic"><PestIcon name="phone" cls="ic" /></span>
            <div><b>Dealing with this at home?</b><p>Call and describe what you are seeing. We will match you with an Englewood-area provider.</p></div>
            <a class="btn btn--red" href={site.phoneHref}>{site.phone}</a>
          </div>
        </article>
        <aside class="sbody-side">
          <div class="side-card side-card--navy">
            <h3>Talk to a local pro</h3>
            <p class="side-note" style="color:#cddbec">Get a plan matched to your home and the pest you are seeing.</p>
            <a class="btn btn--red btn--full" href={site.phoneHref}><PestIcon name="phone" cls="ic" /> {site.phone}</a>
          </div>
          {related.length > 0 && (
            <div class="side-card">
              <h3>Related services</h3>
              <ul class="side-links">{related.map((r) => (<li><a href={`/${r.slug}/`}>{r.label}</a></li>))}</ul>
            </div>
          )}
        </aside>
      </div>
    </section>
    <FaqList faqs={p.faqs} heading="Questions on this topic" />
    <CtaBand />
  </main>
  <Footer />
</Base>
