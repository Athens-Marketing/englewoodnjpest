---
import Base from "../components/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import PestIcon from "../components/PestIcon.astro";
import { site, footerAreas, hours } from "../data/site.js";
import { orgNode, breadcrumb } from "../lib/schema.js";
import { imgUrl } from "../data/imgmap.js";
const path = "/contact/";
const title = `Contact | ${site.brand}`;
const description = "Contact Englewood Pest Control. Call (201) 409-2540 for ants, rodents, termites, roaches, stinging insects, and bed bugs across Englewood and Bergen County.";
const crumbs = [{ name: "Home", path: "/" }, { name: "Contact", path }];
const jsonld = [orgNode(), breadcrumb(crumbs)];
const to12 = (t) => { let [H,M]=t.split(":").map(Number); const ap=H>=12?"PM":"AM"; H=H%12||12; return `${H}:${M.toString().padStart(2,"0")} ${ap}`; };
const hlabel = (h) => (h.days.length > 2 ? `${h.days[0].slice(0,3)}–${h.days[h.days.length-1].slice(0,3)}` : h.days.map(d=>d.slice(0,3)).join(", "));
---
<Base title={title} description={description} path={path} jsonld={jsonld}>
  <Header />
  <main id="main">
    <section class="phero">
      <div class="phero-img"><img src={imgUrl("county.jpg")} alt="" /></div>
      <div class="phero-stars"></div>
      <div class="phero-scrim"></div>
      <div class="wrap phero-in phero-in--area">
        <span class="phero-kick"><PestIcon name="phone" cls="ic" /> Get in touch</span>
        <h1>Contact Englewood Pest Control</h1>
        <p>The fastest way to get help is a phone call. Tell us the pest, the room, and how long it has been going on, and we will match you with a provider covering your address.</p>
        <a class="btn btn--red btn--lg" href={site.phoneHref}><PestIcon name="phone" cls="ic" /> Call {site.phone}</a>
      </div>
    </section>
    <Breadcrumbs items={crumbs} />
    <section class="ct">
      <div class="wrap ct-in">
        <div class="ct-cards">
          <div class="ct-card">
            <span class="ct-ic"><PestIcon name="phone" cls="ic" /></span>
            <h2>Call or text</h2>
            <a class="ct-big" href={site.phoneHref}>{site.phone}</a>
            <p>Fastest way to reach a local pro.</p>
          </div>
          <div class="ct-card">
            <span class="ct-ic"><PestIcon name="mail" cls="ic" /></span>
            <h2>Email</h2>
            <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
            <p>For non-urgent questions.</p>
          </div>
          <div class="ct-card">
            <span class="ct-ic"><PestIcon name="clock" cls="ic" /></span>
            <h2>Hours</h2>
            <p class="ct-hrs">{hours.map((h) => (<span style="display:block">{hlabel(h)}: {to12(h.opens)}–{to12(h.closes)}</span>))}</p>
          </div>
          <div class="ct-card">
            <span class="ct-ic"><PestIcon name="pin" cls="ic" /></span>
            <h2>Areas we serve</h2>
            <p>Englewood and Bergen County.</p>
            <ul class="ct-areas">
              <li><a href="/">Englewood</a></li>
              {footerAreas.map((a) => (<li><a href={`/${a.slug}/`}>{a.name}</a></li>))}
            </ul>
          </div>
        </div>
        <aside class="ct-side">
          <div class="side-card side-card--navy">
            <h3>Why call first</h3>
            <ul class="side-checks">
              <li><PestIcon name="check" cls="ic" /><span>Describe the pest and we match you to the right provider</span></li>
              <li><PestIcon name="check" cls="ic" /><span>Get on the schedule at the earliest open window</span></li>
              <li><PestIcon name="check" cls="ic" /><span>Coverage across Englewood and Bergen County</span></li>
            </ul>
            <a class="btn btn--red btn--full" href={site.phoneHref}><PestIcon name="phone" cls="ic" /> {site.phone}</a>
          </div>
        </aside>
      </div>
    </section>
  </main>
  <Footer />
</Base>
